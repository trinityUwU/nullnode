# Node de rendez-vous. Défaut (dev) : node local ws://127.0.0.1:8791.
# Basculer sur le Pi se fait dans l'app (⚙ RELAY SETTINGS) ou ici au build :
# VITE_RELAY_URL=wss://nullnode.christophercouspeyre.com

# --- Relay : bornes anti-abus (toutes optionnelles, défauts sains) ---
# RELAY_PORT=8791
# RELAY_ENVELOPE_TTL_DAYS=7        # TTL des enveloppes non délivrées (purge auto)
# RELAY_MAX_QUEUE_PER_ADDR=500     # Max enveloppes en attente par adresse (drop FIFO au-delà)
# RELAY_MAX_PAYLOAD_BYTES=65536    # Taille max d'un payload signal/relay (64 KB)
# RELAY_MAX_BACKUP_BYTES=1048576   # Taille max d'un blob de backup (1 MB)
# RELAY_RATE_PER_SEC=30            # Token bucket : messages/seconde par socket
# RELAY_MAX_ADDRESSES=10000        # Max adresses stockées globalement (borne mémoire)
